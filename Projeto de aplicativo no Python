      "cell_type": "code",
      "source": [
        "import json\n",
        "\n",
        "ARQUIVO = \"/content/drive/MyDrive/alunos.json\"\n",
        "\n",
        "# Função responsável por ler os dados do arquivo JSON\n",
        "# Caso o arquivo não exista ou esteja vazio, retorna uma lista vazia\n",
        "def ler_arquivo():\n",
        "    try:\n",
        "        with open(ARQUIVO, \"r\", encoding=\"utf-8\") as arquivo:\n",
        "            alunos = json.load(arquivo)\n",
        "        print(\"Dados lidos do arquivo com sucesso.\")\n",
        "        return alunos\n",
        "    except FileNotFoundError:\n",
        "        print(\"Arquivo não encontrado. Será criada uma lista vazia.\")\n",
        "        return []\n",
        "    except json.JSONDecodeError:\n",
        "        print(\"Arquivo vazio ou corrompido. Será criada uma lista vazia.\")\n",
        "        return []\n",
        "\n",
        "# Função responsável por salvar os dados dos alunos no arquivo JSON\n",
        "def gravar_arquivo(alunos):\n",
        "    with open(ARQUIVO, \"w\", encoding=\"utf-8\") as arquivo:\n",
        "        json.dump(alunos, arquivo, ensure_ascii=False, indent=4)\n",
        "    print(\"Dados gravados no arquivo com sucesso.\")\n",
        "\n",
        "# Função para inserir um novo aluno no sistema\n",
        "# A matrícula é tratada como chave primária e não pode se repetir\n",
        "def inserir_aluno(alunos):\n",
        "    matricula = int(input(\"Digite a matrícula do aluno: \"))\n",
        "\n",
        "    for aluno in alunos:\n",
        "        if aluno[\"matricula\"] == matricula:\n",
        "            print(\"Erro: já existe um aluno com essa matrícula.\")\n",
        "            return\n",
        "\n",
        "    nome = str(input(\"Digite o nome do aluno: \"))\n",
        "    idade = int(input(\"Digite a idade do aluno: \"))\n",
        "    curso = str(input(\"Digite o curso do aluno: \"))\n",
        "    email = input(\"Digite o email do aluno: \")\n",
        "    cidade = str(input(\"Digite a cidade do aluno: \"))\n",
        "\n",
        "    aluno = {\n",
        "        \"matricula\": matricula,\n",
        "        \"nome\": nome,\n",
        "        \"idade\": idade,\n",
        "        \"curso\": curso,\n",
        "        \"email\": email,\n",
        "        \"cidade\": cidade\n",
        "    }\n",
        "\n",
        "    alunos.append(aluno)\n",
        "    print(\"Aluno cadastrado com sucesso.\")\n",
        "\n",
        "# Função para listar todos os alunos cadastrados\n",
        "# Percorre a lista e exibe os dados de cada aluno\n",
        "def listar_alunos(alunos):\n",
        "    if not alunos:\n",
        "        print(\"Nenhum aluno cadastrado.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\nLISTA DE ALUNOS\")\n",
        "    print(\"-\" * 40)\n",
        "\n",
        "    for aluno in alunos:\n",
        "        print(f\"Matrícula: {aluno['matricula']}\")\n",
        "        print(f\"Nome: {aluno['nome']}\")\n",
        "        print(f\"Idade: {aluno['idade']}\")\n",
        "        print(f\"Curso: {aluno['curso']}\")\n",
        "        print(f\"Email: {aluno['email']}\")\n",
        "        print(f\"Cidade: {aluno['cidade']}\")\n",
        "        print(\"-\" * 40)\n",
        "\n",
        "# Função para buscar um aluno pela matrícula\n",
        "def buscar_aluno(alunos):\n",
        "    matricula = int(input(\"Digite a matrícula do aluno que deseja buscar: \"))\n",
        "\n",
        "    for aluno in alunos:\n",
        "        if aluno[\"matricula\"] == matricula:\n",
        "            print(\"\\nAluno encontrado:\")\n",
        "            print(f\"Matrícula: {aluno['matricula']}\")\n",
        "            print(f\"Nome: {aluno['nome']}\")\n",
        "            print(f\"Idade: {aluno['idade']}\")\n",
        "            print(f\"Curso: {aluno['curso']}\")\n",
        "            print(f\"Email: {aluno['email']}\")\n",
        "            print(f\"Cidade: {aluno['cidade']}\")\n",
        "            return\n",
        "\n",
        "    print(\"Aluno não encontrado.\")\n",
        "\n",
        "#Função para alterar dados de um aluno existente pela matrícula\n",
        "def alterar_aluno(alunos):\n",
        "    matricula = int(input(\"Digite a matrícula do aluno que deseja alterar: \"))\n",
        "\n",
        "    for aluno in alunos:\n",
        "        if aluno[\"matricula\"] == matricula:\n",
        "            print(\"Aluno encontrado. Digite os novos dados.\")\n",
        "\n",
        "            aluno[\"nome\"] = str(input(\"Novo nome: \"))\n",
        "            aluno[\"idade\"] = int(input(\"Nova idade: \"))\n",
        "            aluno[\"curso\"] = str(input(\"Novo curso: \"))\n",
        "            aluno[\"email\"] = input(\"Novo email: \")\n",
        "            aluno[\"cidade\"] = str(input(\"Nova cidade: \"))\n",
        "\n",
        "            print(\"Aluno alterado com sucesso.\")\n",
        "            return\n",
        "\n",
        "    print(\"Aluno não encontrado.\")\n",
        "\n",
        "#Função pra excluir um aluno pela matrícula\n",
        "def excluir_aluno(alunos):\n",
        "    matricula = int(input(\"Digite a matrícula do aluno que deseja excluir: \"))\n",
        "\n",
        "    for aluno in alunos:\n",
        "        if aluno[\"matricula\"] == matricula:\n",
        "            alunos.remove(aluno)\n",
        "            print(\"Aluno excluído com sucesso.\")\n",
        "            return\n",
        "\n",
        "    print(\"Aluno não encontrado.\")\n",
        "\n",
        "# Função para ordenar os alunos por qualquer campo escolhido\n",
        "def ordenar_alunos(alunos):\n",
        "    if not alunos:\n",
        "        print(\"Nenhum aluno cadastrado para ordenar.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\nORDENAR POR:\")\n",
        "    print(\"1 - Matrícula\")\n",
        "    print(\"2 - Nome\")\n",
        "    print(\"3 - Idade\")\n",
        "    print(\"4 - Curso\")\n",
        "    print(\"5 - Email\")\n",
        "    print(\"6 - Cidade\")\n",
        "\n",
        "    opcao = input(\"Escolha uma opção: \")\n",
        "\n",
        "    if opcao == \"1\":\n",
        "        alunos.sort(key=lambda x: int(x[\"matricula\"]))\n",
        "    elif opcao == \"2\":\n",
        "        alunos.sort(key=lambda x: x[\"nome\"].lower())\n",
        "    elif opcao == \"3\":\n",
        "        alunos.sort(key=lambda x: int(x[\"idade\"]))\n",
        "    elif opcao == \"4\":\n",
        "        alunos.sort(key=lambda x: x[\"curso\"].lower())\n",
        "    elif opcao == \"5\":\n",
        "        alunos.sort(key=lambda x: x[\"email\"].lower())\n",
        "    elif opcao == \"6\":\n",
        "        alunos.sort(key=lambda x: x[\"cidade\"].lower())\n",
        "    else:\n",
        "        print(\"Opção inválida.\")\n",
        "        return\n",
        "\n",
        "    print(\"Alunos ordenados com sucesso.\")\n",
        "\n",
        "# Função principal do sistema\n",
        "# Controla o menu e chama as outras funções\n",
        "def menu():\n",
        "    alunos = ler_arquivo()\n",
        "\n",
        "    while True:\n",
        "        print(\"\\n===== APLICATIVO CADASTRAL DE ALUNOS =====\")\n",
        "        print(\"1 - Listar alunos\")\n",
        "        print(\"2 - Buscar aluno pela matrícula\")\n",
        "        print(\"3 - Inserir aluno\")\n",
        "        print(\"4 - Alterar aluno\")\n",
        "        print(\"5 - Excluir aluno\")\n",
        "        print(\"6 - Ordenar alunos\")\n",
        "        print(\"7 - Gravar em arquivo\")\n",
        "        print(\"8 - Ler de arquivo\")\n",
        "        print(\"0 - Sair\")\n",
        "\n",
        "        opcao = input(\"Escolha uma opção: \")\n",
        "\n",
        "        if opcao == \"1\":\n",
        "            listar_alunos(alunos)\n",
        "        elif opcao == \"2\":\n",
        "            buscar_aluno(alunos)\n",
        "        elif opcao == \"3\":\n",
        "            inserir_aluno(alunos)\n",
        "        elif opcao == \"4\":\n",
        "            alterar_aluno(alunos)\n",
        "        elif opcao == \"5\":\n",
        "            excluir_aluno(alunos)\n",
        "        elif opcao == \"6\":\n",
        "            ordenar_alunos(alunos)\n",
        "        elif opcao == \"7\":\n",
        "            gravar_arquivo(alunos)\n",
        "        elif opcao == \"8\":\n",
        "            alunos = ler_arquivo()\n",
        "        elif opcao == \"0\":\n",
        "            print(\"Programa encerrado.\")\n",
        "            break\n",
        "        else:\n",
        "            print(\"Opção inválida. Tente novamente.\")\n",
        "\n",
        "\n",
        "menu()"
      ],
