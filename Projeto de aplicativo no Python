import json

ARQUIVO = "/content/drive/MyDrive/alunos.json"

# Função responsável por ler os dados do arquivo JSON
# Caso o arquivo não exista ou esteja vazio, retorna uma lista vazia
def ler_arquivo():
    try:
        with open(ARQUIVO, "r", encoding="utf-8") as arquivo:
            alunos = json.load(arquivo)
        print("Dados lidos do arquivo com sucesso.")
        return alunos
    except FileNotFoundError:
        print("Arquivo não encontrado. Será criada uma lista vazia.")
        return []
    except json.JSONDecodeError:
        print("Arquivo vazio ou corrompido. Será criada uma lista vazia.")
        return []

# Função responsável por salvar os dados dos alunos no arquivo JSON
def gravar_arquivo(alunos):
    with open(ARQUIVO, "w", encoding="utf-8") as arquivo:
        json.dump(alunos, arquivo, ensure_ascii=False, indent=4)
    print("Dados gravados no arquivo com sucesso.")

# Função para inserir um novo aluno no sistema
# A matrícula é tratada como chave primária e não pode se repetir
def inserir_aluno(alunos):
    matricula = int(input("Digite a matrícula do aluno: "))

    for aluno in alunos:
        if aluno["matricula"] == matricula:
            print("Erro: já existe um aluno com essa matrícula.")
            return

    nome = str(input("Digite o nome do aluno: "))
    idade = int(input("Digite a idade do aluno: "))
    curso = str(input("Digite o curso do aluno: "))
    email = input("Digite o email do aluno: ")
    cidade = str(input("Digite a cidade do aluno: "))

    aluno = {
        "matricula": matricula,
        "nome": nome,
        "idade": idade,
        "curso": curso,
        "email": email,
        "cidade": cidade
    }

    alunos.append(aluno)
    print("Aluno cadastrado com sucesso.")

# Função para listar todos os alunos cadastrados
# Percorre a lista e exibe os dados de cada aluno
def listar_alunos(alunos):
    if not alunos:
        print("Nenhum aluno cadastrado.")
        return

    print("\nLISTA DE ALUNOS")
    print("-" * 40)

    for aluno in alunos:
        print(f"Matrícula: {aluno['matricula']}")
        print(f"Nome: {aluno['nome']}")
        print(f"Idade: {aluno['idade']}")
        print(f"Curso: {aluno['curso']}")
        print(f"Email: {aluno['email']}")
        print(f"Cidade: {aluno['cidade']}")
        print("-" * 40)

# Função para buscar um aluno pela matrícula
def buscar_aluno(alunos):
    matricula = int(input("Digite a matrícula do aluno que deseja buscar: "))

    for aluno in alunos:
        if aluno["matricula"] == matricula:
            print("\nAluno encontrado:")
            print(f"Matrícula: {aluno['matricula']}")
            print(f"Nome: {aluno['nome']}")
            print(f"Idade: {aluno['idade']}")
            print(f"Curso: {aluno['curso']}")
            print(f"Email: {aluno['email']}")
            print(f"Cidade: {aluno['cidade']}")
            return

    print("Aluno não encontrado.")

#Função para alterar dados de um aluno existente pela matrícula
def alterar_aluno(alunos):
    matricula = int(input("Digite a matrícula do aluno que deseja alterar: "))

    for aluno in alunos:
        if aluno["matricula"] == matricula:
            print("Aluno encontrado. Digite os novos dados.")

            aluno["nome"] = str(input("Novo nome: "))
            aluno["idade"] = int(input("Nova idade: "))
            aluno["curso"] = str(input("Novo curso: "))
            aluno["email"] = input("Novo email: ")
            aluno["cidade"] = str(input("Nova cidade: "))

            print("Aluno alterado com sucesso.")
            return

    print("Aluno não encontrado.")

#Função pra excluir um aluno pela matrícula
def excluir_aluno(alunos):
    matricula = int(input("Digite a matrícula do aluno que deseja excluir: "))

    for aluno in alunos:
        if aluno["matricula"] == matricula:
            alunos.remove(aluno)
            print("Aluno excluído com sucesso.")
            return

    print("Aluno não encontrado.")

# Função para ordenar os alunos por qualquer campo escolhido
def ordenar_alunos(alunos):
    if not alunos:
        print("Nenhum aluno cadastrado para ordenar.")
        return

    print("\nORDENAR POR:")
    print("1 - Matrícula")
    print("2 - Nome")
    print("3 - Idade")
    print("4 - Curso")
    print("5 - Email")
    print("6 - Cidade")

    opcao = input("Escolha uma opção: ")

    if opcao == "1":
        alunos.sort(key=lambda x: int(x["matricula"]))
    elif opcao == "2":
        alunos.sort(key=lambda x: x["nome"].lower())
    elif opcao == "3":
        alunos.sort(key=lambda x: int(x["idade"]))
    elif opcao == "4":
        alunos.sort(key=lambda x: x["curso"].lower())
    elif opcao == "5":
        alunos.sort(key=lambda x: x["email"].lower())
    elif opcao == "6":
        alunos.sort(key=lambda x: x["cidade"].lower())
    else:
        print("Opção inválida.")
        return

    print("Alunos ordenados com sucesso.")

# Função principal do sistema
# Controla o menu e chama as outras funções
def menu():
    alunos = ler_arquivo()

    while True:
        print("\n===== APLICATIVO CADASTRAL DE ALUNOS =====")
        print("1 - Listar alunos")
        print("2 - Buscar aluno pela matrícula")
        print("3 - Inserir aluno")
        print("4 - Alterar aluno")
        print("5 - Excluir aluno")
        print("6 - Ordenar alunos")
        print("7 - Gravar em arquivo")
        print("8 - Ler de arquivo")
        print("0 - Sair")

        opcao = input("Escolha uma opção: ")

        if opcao == "1":
            listar_alunos(alunos)
        elif opcao == "2":
            buscar_aluno(alunos)
        elif opcao == "3":
            inserir_aluno(alunos)
        elif opcao == "4":
            alterar_aluno(alunos)
        elif opcao == "5":
            excluir_aluno(alunos)
        elif opcao == "6":
            ordenar_alunos(alunos)
        elif opcao == "7":
            gravar_arquivo(alunos)
        elif opcao == "8":
            alunos = ler_arquivo()
        elif opcao == "0":
            print("Programa encerrado.")
            break
        else:
            print("Opção inválida. Tente novamente.")


menu()
